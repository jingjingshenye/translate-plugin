{
  "name": "quick-translate",
  "displayName": "Quick Translate",
  "version": "1.0.0",
  "private": true,
  "description": "划词翻译 + 弹窗翻译浏览器插件",
  "type": "module",
  "scripts": {
    "build": "npm run clear && npm run build:content && npm run build:background && npm run build:popup && npm run manifest",
    "build:popup": "vite build --config vite.config.mts",
    "build:content": "vite build --config vite.config.content.mts",
    "build:background": "vite build --config vite.config.background.mts",
    "manifest": "esno scripts/manifest.ts",
    "clear": "rimraf extension/dist extension/manifest.json",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "vue": "^3.4.38"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.2",
    "esno": "^4.7.0",
    "fs-extra": "^11.2.0",
    "rimraf": "^6.0.1",
    "unocss": "^0.62.2",
    "vite": "^5.4.2"
  }
}
